:root {
}

.mainContainer {
    flex-direction: row;
    flex-grow: 1;
}

.leftPanel {
    flex-grow: 1;
}

.rightPanel {
    flex-grow: 1;
}

.middlePanel {
    flex-grow: 1;
    align-self: center;
    padding-top: 5px;
    padding-right: 5px;
    padding-bottom: 5px;
    padding-left: 5px;
}

.middlePanelButton {
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    border-bottom-right-radius: 16px;
    border-bottom-left-radius: 16px;
    font-size: 20px;
}
