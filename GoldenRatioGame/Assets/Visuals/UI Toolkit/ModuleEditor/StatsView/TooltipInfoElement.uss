.tooltip-info {
    flex-direction: column;

    background-color: var(--ui-bg);
    border-color: var(--ui-border);
    border-width: 2px;
    border-radius: 8px;

    padding: 16px;

    min-width: 280px;
    max-width: 480px;
}

.tooltip-info__top-row {
    flex-direction: row;
    align-items: stretch;
}

.tooltip-info__icon {
    width: 80px;
    height: 80px;
    flex-shrink: 0;

    background-color: var(--ui-icon-bg);
    border-color: var(--ui-icon-border);
    border-width: 2px;
    border-radius: 4px;

    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
}

.tooltip-info__icon--placeholder {
    background-color: var(--ui-icon-bg-placeholder);
    border-color: var(--ui-icon-border-placeholder);
}

.tooltip-info__text-column {
    flex: 1;
    flex-direction: column;
    justify-content: center;

    padding-left: 16px;
}

.tooltip-info__name {
    color: var(--ui-text-tooltip-title);

    font-size: 24px;
    -unity-font-style: bold;

    white-space: normal;

    margin: 0 0 4px 0;
    padding: 0;
}

.tooltip-info__short-desc {
    color: var(--ui-text-tooltip-desc);

    font-size: 20px;
    -unity-font-style: italic;

    white-space: normal;

    margin: 0;
    padding: 0;
}

.tooltip-info__divider {
    height: 2px;
    flex-shrink: 0;

    background-color: var(--ui-border-soft);

    margin-top: 12px;
    margin-bottom: 12px;
}

.tooltip-info__description {
    color: var(--ui-text-tooltip-desc);

    font-size: 20px;

    white-space: normal;

    margin: 0;
    padding: 0;

    -unity-font-definition: url("project://database/Assets/Visuals/Fonts/Thaleah_PixelFont/Materials/ThaleahFat_TTF.ttf?fileID=12800000&guid=585188cdc4600544eb408bee749e4b3a&type=3#ThaleahFat_TTF");
}